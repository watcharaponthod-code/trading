# ─── Alpaca API ────────────────────────────────────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# ─── Telegram Bot ───────────────────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL (set this to your deployed app URL)
# Example: https://your-app.vercel.app/api/telegram/webhook
TELEGRAM_WEBHOOK_URL=https://your-app.vercel.app/api/telegram/webhook

# Admin chat IDs (comma-separated) - these users will receive deploy notifications
# To get your chat ID, send a message to your bot and visit:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
TELEGRAM_ADMIN_CHAT_IDS=123456789,987654321

# ─── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL (Neon / Supabase / etc)
DATABASE_URL=postgresql://user:password@host/database

# ─── App Configuration ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Worker Configuration ────────────────────────────────────────────────────────
WORKER_BASE_URL=http://localhost:3000
WORKER_DRY_RUN=true  # Set to false for live trading
